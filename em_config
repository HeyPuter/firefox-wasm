import os, shutil
EMSDK = os.environ.get('EMSDK', '/usr/lib/emsdk')
EMSCRIPTEN_ROOT = EMSDK + '/upstream/emscripten'
LLVM_ROOT = EMSDK + '/upstream/bin'
# Use the binaryen bundled with the active emsdk (emscripten 6.0.1 ships binaryen
# v130, which accepts the wasm features rustc/LLVM emit -- the old emsdk 3.1.56
# bundled v117 which did NOT, hence the historical system-binaryen override).
# Keeping binaryen version-matched to emcc avoids unsupported-flag mismatches.
# Override with EM_BINARYEN_ROOT (e.g. a system binaryen) if ever needed.
BINARYEN_ROOT = os.environ.get('EM_BINARYEN_ROOT', EMSDK + '/upstream')
NODE_JS = shutil.which('node') or (EMSDK + '/node')
